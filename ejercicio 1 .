import numpy as np
import matplotlib.pyplot as plt
import csv

def gauss_seidel(A, b, tol=1e-6, max_iter=100):
    n = len(b)
    x = np.zeros(n)
    x_prev = np.copy(x)
    errors = []
    
    for k in range(max_iter):
        for i in range(n):
            sum1 = sum(A[i][j] * x[j] for j in range(i))
            sum2 = sum(A[i][j] * x_prev[j] for j in range(i+1, n))
            x[i] = (b[i] - sum1 - sum2) / A[i][i]
        
        abs_error = np.linalg.norm(x - x_prev, ord=np.inf)
        rel_error = abs_error / (np.linalg.norm(x, ord=np.inf) + 1e-10)
        quad_error = np.linalg.norm(x - x_prev) ** 2
        
        errors.append((k+1, abs_error, rel_error, quad_error))
        
        if abs_error < tol:
            break
        x_prev = np.copy(x)
    
    return x, errors

# Sistema del circuito eléctrico
A1 = np.array([[10, 2, 3, 4],
               [2, 12, 2, 3],
               [3, 2, 15, 1],
               [1, 3, 1, 10]])

b1 = np.array([15, 22, 18, 10])

x_sol1, errors1 = gauss_seidel(A1, b1)

# Guardar resultados en CSV
with open("ejercicio1_errors.csv", "w", newline="") as f:
    writer = csv.writer(f)
    writer.writerow(["Iteración", "Error absoluto", "Error relativo", "Error cuadrático"])
    writer.writerows(errors1)
    writer.writerow([])
    writer.writerow(["Solución aproximada"])
    for val in x_sol1:
        writer.writerow([val])

# Graficar errores
iterations = [e[0] for e in errors1]
abs_errors = [e[1] for e in errors1]
rel_errors = [e[2] for e in errors1]
quad_errors = [e[3] for e in errors1]

plt.figure(figsize=(10,5))
plt.plot(iterations, abs_errors, label="Error absoluto")
plt.plot(iterations, rel_errors, label="Error relativo")
plt.plot(iterations, quad_errors, label="Error cuadrático")
plt.yscale("log")
plt.xlabel("Iteraciones")
plt.ylabel("Errores")
plt.title("Convergencia Gauss-Seidel - Ejercicio 1")
plt.legend()
plt.grid()
plt.savefig("ejercicio1_convergencia.png")
plt.show()

print("Solución aproximada Ejercicio 1:", x_sol1)
